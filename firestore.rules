// firestore.rules
// ─────────────────────────────────────────────────────────────────────────────
// Production-ready Firestore security rules for the Noon clone.
// Custom claim  adminClaim = { admin: true }  must be set server-side.
// ─────────────────────────────────────────────────────────────────────────────

rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helper functions ──────────────────────────────────────────────────
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    function isAdmin() {
      return isSignedIn() && request.auth.token.admin == true;
    }

    function validTimestamp(field) {
      return field is timestamp;
    }

    // ── categories ────────────────────────────────────────────────────────
    match /categories/{catId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ── product (singular collection name) ────────────────────────────────
    match /product/{productId} {
      allow read: if true;
      allow write: if isAdmin();

      match /inventory/{invId} {
        allow read: if true;
        // Inventory writes during order placement use server-side transactions.
        allow write: if isAdmin();
      }

      match /reviews/{reviewId} {
        allow read: if true;
        allow create: if isSignedIn()
          && request.resource.data.userId == request.auth.uid
          && request.resource.data.rating is int
          && request.resource.data.rating >= 1
          && request.resource.data.rating <= 5;
        allow update, delete: if isAdmin();
      }

      match /variants/{variantId} {
        allow read: if true;
        allow write: if isAdmin();
      }
    }

    // ── orders ────────────────────────────────────────────────────────────
    match /orders/{orderId} {
      allow read: if isSignedIn()
        && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isSignedIn()
        && request.resource.data.userId == request.auth.uid;
      // Status updates (shipped, delivered) by admin only.
      allow update: if isAdmin()
        || (isSignedIn()
          && resource.data.userId == request.auth.uid
          && request.resource.data.status == 'cancelled'
          && resource.data.status == 'pending');
      allow delete: if false; // soft-delete only via isDeleted flag
    }

    // ── payments ─────────────────────────────────────────────────────────
    match /payments/{paymentId} {
      allow read: if isSignedIn()
        && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isSignedIn()
        && request.resource.data.userId == request.auth.uid;
      // Status updates handled by backend webhooks (admin token).
      allow update: if isAdmin();
      allow delete: if false;
    }

    // ── users ─────────────────────────────────────────────────────────────
    match /users/{userId} {
      allow read, write: if isOwner(userId) || isAdmin();

      match /addresses/{addressId} {
        allow read, write: if isOwner(userId) || isAdmin();
      }

      match /cart/{cartItemId} {
        allow read, write: if isOwner(userId);
      }
    }
  }
}
